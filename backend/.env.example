# Скопируйте в backend/.env (не коммитить!).

# Django
SECRET_KEY=change-me-in-production
DEBUG=true

# База: PostgreSQL на Neon (рекомендуется для деплоя).
# Без DATABASE_URL проект использует SQLite (backend/db.sqlite3).
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# VK
VK_COMMUNITY_TOKEN=
VK_API_VERSION=5.199

# Сброс пароля (Gmail)
