# Скопируйте в backend/.env (не коммитить!).

# VK
VK_COMMUNITY_TOKEN=
VK_API_VERSION=5.199

# Сброс пароля: Gmail travelwithuswtu@gmail.com
# 1) Google-аккаунт → Безопасность → двухэтапная аутентификация
# 2) Пароли приложений → создать «Почта» / «Django»
# 3) Вставьте 16-значный пароль в EMAIL_HOST_PASSWORD (не обычный пароль Gmail!)
FRONTEND_URL=http://127.0.0.1:3100
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=travelwithuswtu@gmail.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=TravelWithUs <travelwithuswtu@gmail.com>
