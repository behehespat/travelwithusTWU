# =============================================================================
# TravelWithUs — переменные для Railway (два сервиса из одного репозитория)
# Скопируйте нужные блоки в Variables каждого сервиса в Railway Dashboard.
# =============================================================================

# --- Сервис BACKEND (Root Directory: backend) ---
# Подключите PostgreSQL в Railway — DATABASE_URL подставится автоматически.

SECRET_KEY=сгенерируйте_длинную_случайную_строку
DEBUG=false
ALLOWED_HOSTS=127.0.0.1,localhost,${{RAILWAY_PUBLIC_DOMAIN}}

# URL фронтенда (после деплоя frontend, например https://travelwithus-web.up.railway.app)
FRONTEND_URL=https://ВАШ-FRONTEND.up.railway.app
CSRF_TRUSTED_ORIGINS=https://ВАШ-FRONTEND.up.railway.app,https://ВАШ-BACKEND.up.railway.app

# Почта (сброс пароля)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=travelwithuswtu@gmail.com
EMAIL_HOST_PASSWORD=пароль_приложения_gmail
DEFAULT_FROM_EMAIL=TravelWithUs <travelwithuswtu@gmail.com>

# VK-бот (опционально)
VK_COMMUNITY_TOKEN=
VK_API_VERSION=5.199

# --- Сервис FRONTEND (Root Directory: frontend) ---
# API_URL нужен при сборке (proxy /api → backend) и для SSR.

API_URL=https://${{ travelwithusTWU.RAILWAY_PUBLIC_DOMAIN }}
# Опционально (если не задан — браузер использует same-origin /api через Next proxy):
NEXT_PUBLIC_API_URL=https://${{ travelwithusTWU.RAILWAY_PUBLIC_DOMAIN }}
